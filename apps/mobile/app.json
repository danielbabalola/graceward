{
  "expo": {
    "name": "Graceward",
    "slug": "graceward",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "graceward",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.graceward.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Graceward to use the microphone so you can record voice reflections. Audio stays private on your device."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
