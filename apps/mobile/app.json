{
  "expo": {
    "name": "Graceward",
    "slug": "graceward",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "graceward",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#12324A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.graceward.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#12324A"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Graceward to use the microphone so you can record voice reflections. Audio stays private on your device."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
