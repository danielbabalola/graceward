{
  "expo": {
    "name": "Graceward",
    "slug": "graceward",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "graceward",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#12324A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.graceward.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#12324A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Graceward to use the microphone so you can record voice reflections. Audio stays private on your device."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c78af8d0-f0b8-499d-ae31-e6ba7bd9ef38"
      }
    }
  }
}
