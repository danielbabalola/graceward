PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# AI provider (server-side only — never expose these to the mobile app).
# If OPENAI_API_KEY is missing, the AI endpoints (/ai/analyze-reflection,
# /ai/transcribe-reflection, /ai/structure-voice-entry) return a clear
# AI_NOT_CONFIGURED error instead of calling any provider.
OPENAI_API_KEY=
# Optional. Defaults to gpt-5.4-mini when unset.
# Suggested tiers: gpt-5.4-mini (daily reflections), gpt-4o-mini (cheap dev),
# gpt-5.5 (deeper weekly/monthly reviews later).
OPENAI_MODEL=gpt-5.4-mini

# Optional. Model used by POST /ai/transcribe-reflection for manual voice
# transcription. Defaults to gpt-4o-mini-transcribe when unset. Must be an
# OpenAI model available through the audio transcriptions endpoint
# (e.g. gpt-4o-mini-transcribe, gpt-4o-transcribe, whisper-1).
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Optional. Only for reasoning models (gpt-5.x): minimal | low | medium | high.
# Leave blank for non-reasoning models such as gpt-4o-mini.
OPENAI_REASONING_EFFORT=

# Optional. Max time (ms) to wait for the AI provider before returning a safe
# AI_TIMEOUT error. Defaults to 30000 (30s) for analysis; transcription uses a
# 60s floor since audio transcription is slower.
AI_PROVIDER_TIMEOUT_MS=30000

# --- Content moderation (input + output) ---
# Runs the OpenAI moderation endpoint on user input (reflection text /
# transcript) before the paid call, and on model output before returning it.
# Blocked content returns a calm 422 CONTENT_FLAGGED. On a moderation outage it
# FAILS OPEN (proceeds) so the pastoral path is never silently broken. Uses the
# same OPENAI_API_KEY; the moderation endpoint itself is free.
# On by default when a key is set. Set to a false-y value to disable.
AI_MODERATION_ENABLED=true
# Optional. Moderation model. Defaults to omni-moderation-latest.
AI_MODERATION_MODEL=omni-moderation-latest
# Optional. Comma-separated moderation categories that BLOCK. Defaults to
# clearly-illegitimate categories only, so a hurting believer can still bring
# self-harm, violence experienced, sexual sin/struggle, or anger to God and
# reach the pastoral crisis path. Default:
#   sexual/minors,harassment/threatening,hate/threatening,illicit/violent
AI_MODERATION_BLOCK_CATEGORIES=
# Optional. Moderation request timeout (ms). Defaults to 10000 (10s).
AI_MODERATION_TIMEOUT_MS=10000

# Optional. In-memory rate limit for the AI endpoints, per client IP, for burst
# abuse. Conservative dev-friendly defaults: 20 requests per 60-second window.
# Returns 429 RATE_LIMITED when exceeded. In-memory only (single instance, no
# Redis). Applies to all three AI endpoints.
AI_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_WINDOW_SECONDS=60

# --- Closed-beta AI access control (anonymous per-install ID + daily quotas) ---
# This is closed-beta cost/abuse protection, NOT real user auth, accounts, or
# subscriptions. The mobile app generates a random anonymous install ID locally
# (not derived from device/advertising identifiers) and sends it in the
# X-Graceward-Install-Id header with AI requests. Requests without a valid
# install ID get a 401 INSTALL_ID_REQUIRED.

# Emergency kill switch. When false (or 0/off/no), all three AI endpoints return
# a safe 503 AI_DISABLED before any paid provider call. Defaults to enabled.
AI_ENDPOINTS_ENABLED=true

# Per-install daily quotas (UTC day). Checked before each paid provider call;
# exceeding any cap returns 429 AI_QUOTA_EXCEEDED with a Retry-After header.
# A request is only counted after its paid provider call succeeds, so failed
# validations are never charged against the quota. Conservative beta defaults.
AI_DAILY_TOTAL_QUOTA_PER_INSTALL=40
AI_DAILY_ANALYZE_QUOTA_PER_INSTALL=30
AI_DAILY_TRANSCRIBE_QUOTA_PER_INSTALL=15
AI_DAILY_STRUCTURE_QUOTA_PER_INSTALL=15

# Optional. Path to the JSON file backing per-install quota counts. Defaults to
# ./.data/ai-quota.json (relative to the API working directory). Easy to swap
# for Redis/Postgres later. Stores only opaque install IDs and integer counts —
# never any request content.
AI_QUOTA_STORE_PATH=./.data/ai-quota.json
